# Copia este archivo a `.env` y rellena los valores reales (NUNCA subas `.env`).
#
# Supabase expone dos cadenas de conexión:
# - DATABASE_URL: a través del pooler (la usa la app en runtime).
# - DIRECT_URL:   conexión directa (la usa Prisma para migraciones).
# Se obtienen en: Supabase > Project Settings > Database > Connection string.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Autenticación mínima (contraseña única de administrador, ver docs/adr/0009).
# ADMIN_PASSWORD: la contraseña de acceso al panel.
# SESSION_SECRET: clave para firmar la cookie de sesión (independiente de la
# contraseña). Genera una con: openssl rand -hex 32
ADMIN_PASSWORD="changeme"
SESSION_SECRET="replace-with-a-random-32-byte-hex-string"
